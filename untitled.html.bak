                    alertX2: "✨ MYTHIC! Current score multiplied by 2x!", 
                    alertDot: "🎯 LUCKY! Next hand turned into [1x1 Rescue Dots]!", 
                    alertSelect: "🔮 SELECTOR! Shape index unlocked, pick 3 shapes!",
