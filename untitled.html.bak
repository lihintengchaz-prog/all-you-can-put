<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ALL YOU CAN PUT! - Smart Assist Edition</title>
    <link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css">
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <style>
        /* ==========================================================================
           1. CORE CSS ARCHITECTURE (GLOBAL VARIABLES & THEME ENGINE)
           ========================================================================== */
        :root {
            /* 商業級高對比色彩庫 */
            --pink: #ff3377;
            --blue: #00e5ff;
            --yellow: #ffea00;
            --purple: #d500f9;
            --orange: #ff6d00;
            --green: #00ff66;
            --danger: #ff1744;
            
            /* 介面與陰影 */
            --panel-bg: rgba(22, 27, 49, 0.88);
            --modal-bg: #1c2136;
            --grid-dark: #121626;
            --grid-empty: #1d223a;
            
            /* 預設海洋主題漸變 */
            --bg-gradient: linear-gradient(135deg, #ff99ca 0%, #4facfe 50%, #171b36 100%);
            --font-main: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: var(--font-main);
            background: var(--bg-gradient);
            color: #fff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            transition: background 1.2s cubic-bezier(0.25, 1, 0.5, 1);
        }

        /* ==========================================================================
           2. UI LAYOUT & MENUS (LOBBY ARCHITECTURE)
           ========================================================================== */
        #menu-screen {
            text-align: center;
            max-width: 900px;
            width: 100%;
            padding: 30px 20px;
            z-index: 10;
            animation: appStartContainer 0.5s ease-out;
        }

        .lobby-header {
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            margin-bottom: 10px;
            padding: 10px;
        }

        .logo-title {
            font-size: clamp(3rem, 8vw, 5rem);
            font-weight: 900;
            background: linear-gradient(45deg, #ffffff, var(--blue), var(--pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
            filter: drop-shadow(3px 5px 12px rgba(0,0,0,0.4));
        }

        .lobby-settings-btn {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: #fff;
            font-size: 1.5rem;
            width: 48px;
            height: 48px;
            border-radius: 16px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(10px);
            transition: all 0.25s ease;
        }

        .lobby-settings-btn:hover {
            background: var(--blue);
            transform: translateY(-50%) scale(1.08) rotate(45deg);
            border-color: #fff;
            box-shadow: 0 0 15px var(--blue);
        }

        .subtitle {
            color: #1a223d;
            font-size: clamp(1rem, 3vw, 1.3rem);
            margin-bottom: 40px;
            letter-spacing: 5px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .mode-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
        }

        .mode-card {
            background: var(--panel-bg);
            border-radius: 32px;
            padding: 35px 25px;
            cursor: pointer;
            backdrop-filter: blur(15px);
            box-shadow: 0 20px 45px rgba(0,0,0,0.3);
            border: 2px solid rgba(255,255,255,0.08);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
        }

        .mode-card:hover {
            transform: translateY(-10px);
            border-color: var(--blue);
            box-shadow: 0 30px 60px rgba(0,242,254,0.2);
        }

        .mode-card h3 {
            font-size: 1.8rem;
            margin-bottom: 15px;
            font-weight: 800;
            letter-spacing: 1px;
        }

        .mode-card p {
            color: #bbc6e0;
            font-size: 0.95rem;
            margin-bottom: 30px;
            line-height: 1.6;
            text-align: center;
            height: 75px;
        }

        .play-btn {
            background: linear-gradient(45deg, var(--pink), var(--blue));
            color: #fff;
            border: none;
            padding: 14px 45px;
            font-weight: 800;
            border-radius: 16px;
            font-size: 1.05rem;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(255, 51, 119, 0.3);
            transition: all 0.2s ease;
        }

        .play-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 12px 25px rgba(0, 229, 255, 0.4);
        }

        .continue-btn {
            background: linear-gradient(45deg, var(--yellow), var(--orange));
            color: #000;
            margin: 0 auto 30px auto;
            display: none;
            font-weight: 900;
            letter-spacing: 1px;
            border: 2px solid #000;
            box-shadow: 0 10px 25px rgba(255, 234, 0, 0.4);
            animation: pulseGlowAnimation 1.6s infinite alternate;
        }

        /* 66關選擇面板樣式 */
        #level-select-panel {
            display: none;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-top: 25px;
            width: 100%;
            max-height: 180px;
            overflow-y: auto;
            padding: 12px;
            background: rgba(0, 0, 0, 0.25);
            border-radius: 20px;
            box-sizing: border-box;
            border: 1px solid rgba(255,255,255,0.05);
        }

        #level-select-panel::-webkit-scrollbar {
            width: 6px;
        }

        #level-select-panel::-webkit-scrollbar-thumb {
            background: var(--pink);
            border-radius: 3px;
        }

        .lvl-btn {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            padding: 10px;
            border-radius: 12px;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .lvl-btn:hover {
            background: var(--pink);
            border-color: #fff;
            transform: scale(1.08);
            box-shadow: 0 0 12px var(--pink);
        }

        /* ==========================================
           3. GAME INTERFACE & CANVARENA LAYOUT
           ========================================== */
        #game-screen {
            display: none;
            width: 100%;
            max-width: 850px;
            gap: 30px;
            padding: 15px;
            box-sizing: border-box;
            justify-content: center;
            align-items: flex-start;
        }

        .main-game-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
            max-width: 460px;
        }

        .score-board-top {
            display: flex;
            width: 100%;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding: 0 8px;
            box-sizing: border-box;
        }

        .left-nav-group {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .home-icon-btn, .settings-gear-btn {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: #fff;
            font-size: 1.4rem;
            width: 46px;
            height: 46px;
            border-radius: 16px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(8px);
            transition: all 0.2s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .home-icon-btn:hover { background: var(--pink); transform: scale(1.06); border-color: #fff; }
        .settings-gear-btn:hover { background: var(--blue); transform: scale(1.06) rotate(45deg); border-color: #fff; }

        .score-left-box {
            display: flex;
            flex-direction: column;
        }

        .top-score-text {
            font-size: 2.2rem;
            font-weight: 900;
            color: #fff;
            line-height: 1;
            text-shadow: 2px 3px 6px rgba(0,0,0,0.3);
        }

        .top-best-text {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1a223d;
            margin-top: 2px;
        }

        .status-indicators-bar {
            width: 100%;
            display: flex;
            gap: 12px;
            margin-bottom: 15px;
            box-sizing: border-box;
        }

        .indicator-tag {
            flex: 1;
            background: rgba(0,0,0,0.3);
            padding: 10px;
            border-radius: 14px;
            font-weight: 800;
            font-size: 0.95rem;
            text-align: center;
            box-sizing: border-box;
            border: 1px solid rgba(255,255,255,0.08);
            backdrop-filter: blur(5px);
            transition: all 0.3s;
        }

        #lucky-progress-bar { display: none; color: var(--yellow); border-color: rgba(255, 234, 0, 0.25); }
        #clear-multiplier-tag { color: var(--green); border-color: rgba(0, 255, 102, 0.25); }

        .arena {
            background: var(--panel-bg);
            backdrop-filter: blur(15px);
            padding: 18px;
            border-radius: 36px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.4);
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
            box-sizing: border-box;
            transition: background 0.6s ease, box-shadow 0.6s ease;
            position: relative;
        }

        canvas {
            display: block;
            border-radius: 24px;
            max-width: 100%;
            border: 1px solid rgba(255,255,255,0.05);
            background: var(--grid-dark);
            z-index: 1;
        }

        /* ==========================================
           4. 🔮 RIGHT SELECT PANEL (PIXEL PERFECT ADAPTATION)
           ========================================== */
        #custom-select-panel {
            display: none;
            flex-direction: column;
            background: var(--panel-bg);
            border-radius: 28px;
            padding: 18px;
            border: 2px solid var(--purple);
            max-height: 700px;
            overflow-y: auto;
            width: 240px;
            box-sizing: border-box;
            gap: 15px;
            backdrop-filter: blur(15px);
            box-shadow: 0 30px 60px rgba(0,0,0,0.4);
            align-items: center;
            animation: panelSlideIn 0.3s cubic-bezier(0.25, 1, 0.5, 1);
        }

        #custom-select-panel::-webkit-scrollbar { width: 5px; }
        #custom-select-panel::-webkit-scrollbar-thumb { background: var(--purple); border-radius: 3px; }

        .select-item-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }

        .select-item-card {
            background: #111422;
            border: 1px solid rgba(255,255,255,0.08);
            padding: 12px;
            border-radius: 18px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            box-sizing: border-box;
            width: 170px;
            height: 140px;
            transition: all 0.2s ease;
        }

        .select-item-card:hover {
            border-color: var(--purple);
            background: rgba(213, 0, 249, 0.12);
            transform: scale(1.04);
        }

        .select-item-name {
            font-size: 0.8rem;
            font-weight: 800;
            color: #9aa7c4;
            margin-top: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ==========================================
           5. PREMIUM OVERLAY MODALS (ANTI-PENETRATION & HIGH Z-INDEX)
           ========================================== */
        .overlay-window {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(6, 7, 15, 0.88);
            z-index: 999999; /* 絕對死鎖超高層級，防止事件穿透 */
            flex-direction: column;
            justify-content: center;
            align-items: center;
            pointer-events: auto;
            backdrop-filter: blur(8px);
        }

        .modal-box {
            background: #1c2136;
            padding: 35px 40px;
            border-radius: 32px;
            text-align: center;
            box-shadow: 0 25px 55px rgba(0,0,0,0.6);
            max-width: 350px;
            width: 90%;
            border: 2px solid rgba(255, 255, 255, 0.08);
            animation: modalPopIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .modal-box h2 {
            margin-bottom: 18px;
            font-size: 2.2rem;
            font-weight: 900;
            letter-spacing: 1px;
        }

        .modal-box p {
            margin-bottom: 25px;
            font-size: 1.15rem;
            color: #a2aed4;
            font-weight: bold;
            line-height: 1.5;
        }

        .modal-btns {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .modal-btn {
            padding: 14px;
            border-radius: 16px;
            border: none;
            font-size: 1.05rem;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

        .modal-btn:hover {
            transform: translateY(-2px);
        }

        .btn-retry { background: linear-gradient(45deg, var(--pink), var(--blue)); color: #fff; box-shadow: 0 6px 15px rgba(255,51,119,0.3); }
        .btn-menu { background: #2d3554; color: #fff; border: 1px solid rgba(255,255,255,0.05); }
        .btn-close { background: #475070; color: #fff; }
        
        .btn-retry:hover { box-shadow: 0 10px 20px rgba(0,229,255,0.4); }
        .btn-menu:hover { background: #384268; }

        /* 語言切換盒子 */
        .lang-toggle-box {
            margin: 5px 0 25px 0;
            background: rgba(0,0,0,0.2);
            padding: 14px 18px;
            border-radius: 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(255,255,255,0.04);
        }

        .lang-label { font-size: 1rem; font-weight: 700; color: #a4b3dc; }
        .lang-btn-group { display: flex; gap: 10px; }
        
        .lang-sub-btn {
            background: #2a314e;
            border: 1px solid rgba(255,255,255,0.08);
            color: #fff;
            padding: 8px 18px;
            border-radius: 10px;
            font-weight: bold;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .lang-sub-btn.active {
            background: var(--blue);
            color: #000;
            border-color: #fff;
            box-shadow: 0 0 10px rgba(0,229,255,0.5);
        }

        /* 幸運寶箱抖動動畫 */
        .chest-anim {
            font-size: 6rem;
            margin-bottom: 15px;
            display: inline-block;
            animation: chestWobbleLoop 0.4s ease infinite alternate;
            cursor: pointer;
            filter: drop-shadow(0 8px 25px rgba(255,234,0,0.4));
            transition: transform 0.2s;
        }

        .chest-anim:hover {
            transform: scale(1.15);
        }

        /* ==========================================================================
           6. ADVANCED KEYFRAMES & ANIMATIONS
           ========================================================================== */
        @keyframes fadeIn { 
            from { opacity: 0; transform: scale(0.96); } 
            to { opacity: 1; transform: scale(1); } 
        }
        @keyframes appStartContainer { 
            from { opacity: 0; transform: translateY(20px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        @keyframes panelSlideIn { 
            from { opacity: 0; transform: translateX(40px); } 
            to { opacity: 1; transform: translateX(0); } 
        }
        @keyframes modalPopIn { 
            from { opacity: 0; transform: scale(0.85) translateY(40px); } 
            to { opacity: 1; transform: scale(1) translateY(0); } 
        }
        @keyframes chestWobbleLoop { 
            from { transform: rotate(-8deg); } 
            to { transform: rotate(8deg); } 
        }
        @keyframes pulseGlowAnimation { 
            from { box-shadow: 0 0 10px var(--yellow); } 
            to { box-shadow: 0 0 35px var(--orange); transform: scale(1.03); } 
        }
    </style>
</head>
<body>

    <div id="menu-screen">
        <div class="lobby-header">
            <div class="logo-title">ALL YOU CAN PUT!</div>
            <button class="lobby-settings-btn" onclick="GameApp.UI.openSettingsModal()">⚙️</button>
        </div>
        <div class="subtitle" id="lobby-sub">AI智能爽快全清 ‧ 三連自選改命版</div>
        
        <button class="play-btn continue-btn" id="lobby-continue-btn" onclick="GameApp.Core.loadSavedGame()">CONTINUE</button>

        <div class="mode-container">
            <div class="mode-card" onclick="GameApp.Core.startLuckyMode()">
                <h3 id="mode-lucky-title">幸運模式 (Lucky)</h3>
                <p id="mode-lucky-desc">每消除滿 3 行即可抽取幸運寶箱！觸發高額分數翻倍與方塊自選改命！</p>
                <button class="play-btn" style="background: linear-gradient(45deg, var(--yellow), var(--orange)); color: #000;">LUCKY PLAY</button>
            </div>
            
            <div class="mode-card" onclick="GameApp.Core.startEndlessMode()">
                <h3 id="mode-endless-title">無盡模式 (Endless)</h3>
                <p id="mode-endless-desc">經典刷分。AI 智能放水輔助清屏，享受滿屏極速全清棋盤的無限爽感！</p>
                <button class="play-btn">START</button>
            </div>
            
            <div class="mode-card" id="level-card">
                <h3 id="mode-level-title">闖關模式 (Levels)</h3>
                <p id="mode-level-desc">挑戰由淺入深的 66 道經典關卡！繞開固定死局障礙鐵塊，衝擊通關目標。</p>
                <button class="play-btn" onclick="GameApp.UI.toggleLevelSelect(event)">STAGES</button>
                <div id="level-select-panel">
                    </div>
            </div>
        </div>
    </div>

    <div id="game-screen">
        <div class="main-game-area">
            
            <div class="score-board-top">
                <div class="left-nav-group">
                    <button class="home-icon-btn" onclick="GameApp.Core.exitToMenu()">🏠</button>
                    <div class="score-left-box">
                        <div class="top-score-text" id="topScoreText">SCORE: 0</div>
                        <div class="top-best-text" id="topBestText">BEST: 0</div>
                    </div>
                </div>
                <button class="settings-gear-btn" onclick="GameApp.UI.openSettingsModal()">⚙️</button>
            </div>

            <div class="status-indicators-bar">
                <div id="clear-multiplier-tag" class="indicator-tag">清屏倍率: 1.0x</div>
                <div id="lucky-progress-bar" class="indicator-tag">距離寶箱還剩: 3 行</div>
            </div>

            <div class="arena" id="gameArenaPanel">
                <canvas id="blockCanvas" width="440" height="660"></canvas>
            </div>
        </div>

        <div id="custom-select-panel">
            <div style="text-align:center; font-size:1.05rem; font-weight:900; color:var(--purple); margin-bottom:10px; letter-spacing:1px;" id="panel-select-title">🔮 挑選 3 個形狀</div>
            </div>
    </div>

    <div id="lucky-chest-overlay" class="overlay-window">
        <div class="modal-box" style="border: 3px solid var(--yellow);" onclick="event.stopPropagation()">
            <div class="chest-anim" id="chest-gift-box" onclick="GameApp.Core.drawLuckyChest()">🎁</div>
            <h2 style="color: var(--yellow); margin-bottom: 8px;" id="chest-title">幸運寶箱！</h2>
            <p style="color: #fff; font-size: 1.05rem; margin-bottom:25px;" id="chest-desc">消除滿 3 行解鎖，點擊開啟逆天改命</p>
            <div class="modal-btns">
                <button class="modal-btn btn-retry" style="background: linear-gradient(45deg, var(--yellow), var(--orange)); color:#000; box-shadow: 0 5px 15px rgba(255,234,0,0.4);" id="chest-open-btn" onclick="GameApp.Core.drawLuckyChest()">開 啟 寶 箱</button>
            </div>
        </div>
    </div>

    <div id="settings-overlay" class="overlay-window">
        <div class="modal-box" onclick="event.stopPropagation()">
            <h2 style="color: var(--blue);" id="settings-title">遊戲設置</h2>
            
            <div class="lang-toggle-box">
                <span class="lang-label" id="lang-label-text">語言 / Language</span>
                <div class="lang-btn-group">
                    <button class="lang-sub-btn" id="lang-zh" onclick="GameApp.I18N.changeLanguage('zh')">中文</button>
                    <button class="lang-sub-btn" id="lang-en" onclick="GameApp.I18N.changeLanguage('en')">EN</button>
                </div>
            </div>

            <div class="modal-btns">
                <button class="modal-btn btn-retry" id="settings-retry" onclick="GameApp.UI.triggerReplayFromSettings()">🔄 重新開始</button>
                <button class="modal-btn btn-menu" id="settings-lobby" onclick="GameApp.UI.triggerMenuFromSettings()">🚪 返回主頁</button>
                <button class="modal-btn btn-close" id="settings-close" onclick="GameApp.UI.closeSettingsModal()">關閉面板</button>
            </div>
        </div>
    </div>

    <div id="gameover-overlay" class="overlay-window">
        <div class="modal-box" onclick="event.stopPropagation()">
            <h2 id="modalTitle" style="color: var(--pink);">遊戲結束</h2>
            <p id="modalScoreText">最終得分: 0</p>
            <div class="modal-btns">
                <button class="modal-btn btn-retry" id="go-retry" onclick="GameApp.Core.resetGame()">再開一局</button>
                <button class="modal-btn btn-menu" id="go-lobby" onclick="GameApp.Core.exitToMenu()">返回大廳</button>
            </div>
        </div>
    </div>

    <script>
        /**
         * ALL YOU CAN PUT! - CORE ENGINE
         * 採用物件導向與模組化設計，增強可讀性、擴展性，並為商業變現做準備。
         */
        const GameApp = {};

        // ----------------------------------------------------------------------
        // MODULE: CONFIGURATION & CONSTANTS
        // ----------------------------------------------------------------------
        GameApp.Config = {
            bGridSize: 8,
            bCellSize: 440 / 8, // 55px
            maxLevel: 66,
            luckyLineTarget: 3,
            
            // 🌟 核心修改：單點與十字架移出普通池，改為隱藏款
            Shapes: {
                easy: [
                    { name: "square", matrix: [[1,1],[1,1]], color: '#ff3377' }, 
                    { name: "bar-3", matrix: [[1,1,1]], color: '#00e5ff' },      
                    { name: "vbar-3", matrix: [[1],[1],[1]], color: '#00e5ff' }, 
                    { name: "bar-2", matrix: [[1,1]], color: '#ffea00' }
                ],
                medium: [
                    { name: "bar-4", matrix: [[1,1,1,1]], color: '#ff6d00' }, 
                    { name: "vbar-4", matrix: [[1],[1],[1],[1]], color: '#ff6d00' },
                    { name: "t-shape", matrix: [[1,1,1],[0,1,0]], color: '#d500f9' }, 
                    { name: "l-shape", matrix: [[1,0],[1,0],[1,1]], color: '#ff3377' },
                    { name: "z-shape", matrix: [[1,1,0],[0,1,1]], color: '#ffea00' }
                ],
                hard: [
                    { name: "big-l-3x3", matrix: [[1,0,0],[1,0,0],[1,1,1]], color: '#ff6d00' }
                ],
                // 隱藏VIP款（僅限自選面板出現）
                special: [
                    { name: "dot", matrix: [[1]], color: '#00ff66' },
                    { name: "cross-3x3", matrix: [[0,1,0],[1,1,1],[0,1,0]], color: '#d500f9' }
                ]
            },

            Themes: {
                sea: { 
                    bg: 'linear-gradient(135deg, #ff99ca 0%, #4facfe 50%, #171b36 100%)', 
                    panel: 'rgba(22, 27, 49, 0.85)', 
                    emptyCell: '#1d223a',
                    canvasFill: '#121626'
                },
                grass: { 
                    bg: 'linear-gradient(135deg, #11998e 0%, #38ef7d 100%)', 
                    panel: 'rgba(17, 43, 31, 0.85)', 
                    emptyCell: '#1e382b',
                    canvasFill: '#0d2117'
                },
                sunset: { 
                    bg: 'linear-gradient(135deg, #ff7b54 0%, #ffb26b 50%, #6b4f4f 100%)', 
                    panel: 'rgba(66, 43, 43, 0.85)', 
                    emptyCell: '#3c2828',
                    canvasFill: '#241818'
                },
                universe: { 
                    bg: 'linear-gradient(135deg, #0f051d 0%, #05020a 100%)', 
                    panel: 'rgba(25, 12, 43, 0.9)', 
                    emptyCell: '#211534',
                    canvasFill: '#0c0616'
                }
            }
        };

        // ----------------------------------------------------------------------
