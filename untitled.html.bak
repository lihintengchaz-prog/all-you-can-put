            init: function() {
                this.currentLang = localStorage.getItem('block_put_lang') || 'zh';
                this.applyLanguage();
            },

            changeLanguage: function(lang) {
                this.currentLang = lang;
                localStorage.setItem('block_put_lang', lang);
                this.applyLanguage();
            },

            applyLanguage: function() {
                const t = this.dictionary[this.currentLang];
                
                document.getElementById('lobby-sub').innerText = t.sub;
                document.getElementById('mode-lucky-title').innerText = t.luckyTitle;
                document.getElementById('mode-lucky-desc').innerText = t.luckyDesc;
                document.getElementById('mode-endless-title').innerText = t.endlessTitle;
                document.getElementById('mode-endless-desc').innerText = t.endlessDesc;
                document.getElementById('mode-level-title').innerText = t.levelTitle;
                document.getElementById('mode-level-desc').innerText = t.levelDesc;
                document.getElementById('level-card').querySelector('.play-btn').innerText = t.stagesBtn;
                document.getElementById('lobby-continue-btn').innerText = t.continueBtn;
                
                document.getElementById('panel-select-title').innerText = t.selectTitle;
                document.getElementById('settings-title').innerText = t.settingsTitle;
                document.getElementById('settings-retry').innerText = t.btnRetry;
                document.getElementById('settings-lobby').innerText = t.btnLobby;
                document.getElementById('settings-close').innerText = t.btnClose;
                document.getElementById('chest-title').innerText = t.chestTitle;
                document.getElementById('chest-desc').innerText = t.chestDesc;
                document.getElementById('chest-open-btn').innerText = t.chestOpen;
                document.getElementById('go-retry').innerText = t.goRetryBtn;
                document.getElementById('go-lobby').innerText = t.goLobbyBtn;
                
                document.getElementById('lang-zh').className = 'lang-sub-btn' + (this.currentLang === 'zh' ? ' active' : '');
                document.getElementById('lang-en').className = 'lang-sub-btn' + (this.currentLang === 'en' ? ' active' : '');
                
                GameApp.UI.updateScoreDisplay();
                GameApp.Core.checkSavedGameExists();
            },

            getText: function(key) {
                return this.dictionary[this.currentLang][key];
            }
        };

        // ----------------------------------------------------------------------
        // MODULE: ADS & MONETIZATION ENGINE (商業變現模擬)
        // ----------------------------------------------------------------------
        GameApp.AdsManager = {
            init: function() {
                console.log("[AdsManager] Monetization SDK Ready.");
            },
            showInterstitial: function(callback) {
                // Future Implementation: crazygames.showInterstitial().then(callback);
                if(callback) callback();
            }
        };

        // ----------------------------------------------------------------------
        // MODULE: USER INTERFACE (UI) & MODALS
        // ----------------------------------------------------------------------
        GameApp.UI = {
            elements: {},

            init: function() {
                this.elements.canvas = document.getElementById('blockCanvas');
                this.elements.ctx = this.elements.canvas.getContext('2d');
                this.elements.topScoreText = document.getElementById('topScoreText');
                this.elements.topBestText = document.getElementById('topBestText');
                this.elements.gameoverOverlay = document.getElementById('gameover-overlay');
                this.elements.settingsOverlay = document.getElementById('settings-overlay');
                this.elements.luckyChestOverlay = document.getElementById('lucky-chest-overlay');
                this.elements.luckyProgressBar = document.getElementById('lucky-progress-bar');
                this.elements.clearMultiplierTag = document.getElementById('clear-multiplier-tag');
                this.elements.customSelectPanel = document.getElementById('custom-select-panel');
                this.elements.modalTitle = document.getElementById('modalTitle');
                this.elements.modalScoreText = document.getElementById('modalScoreText');
                this.elements.levelPanel = document.getElementById('level-select-panel');

                this.generateLevelButtons();
                this.generateCustomShapePanel();
            },

            generateLevelButtons: function() {
                for (let i = 1; i <= GameApp.Config.maxLevel; i++) {
                    let btn = document.createElement('button');
                    btn.className = 'lvl-btn';
                    btn.innerText = i < 10 ? '0' + i : i;
                    btn.onclick = (e) => { e.stopPropagation(); GameApp.Core.startLevelMode(i); };
                    this.elements.levelPanel.appendChild(btn);
                }
            },

            generateCustomShapePanel: function() {
                // 將特殊形狀也加入圖庫供玩家挑選
                const ALL_SHAPES = [
                    ...GameApp.Config.Shapes.easy, 
                    ...GameApp.Config.Shapes.medium, 
                    ...GameApp.Config.Shapes.hard,
                    ...GameApp.Config.Shapes.special
                ];

                ALL_SHAPES.forEach((item) => {
                    let wrapper = document.createElement('div');
                    wrapper.className = 'select-item-wrapper';
                    
                    let itemCard = document.createElement('div');
                    itemCard.className = 'select-item-card';
                    
                    const selectCellSize = 26; 
                    const maxMatrixDim = 3; 
                    
                    itemCard.innerHTML = `<canvas width="${maxMatrixDim * selectCellSize}" height="${maxMatrixDim * selectCellSize}"></canvas>`;
                    let sCtx = itemCard.querySelector('canvas').getContext('2d');
                    
                    // 繪製背景暗格
                    for(let r=0; r<maxMatrixDim; r++) {
                        for(let c=0; c<maxMatrixDim; c++) {
                            sCtx.fillStyle = "rgba(255,255,255,0.05)";
                            sCtx.fillRect(c * selectCellSize + 1, r * selectCellSize + 1, selectCellSize - 2, selectCellSize - 2);
                        }
                    }
                    
                    // 繪製實體圖形
                    item.matrix.forEach((row, r) => {
                        row.forEach((v, c) => { 
                            if(v) GameApp.Render.drawTexturedCandyCell(sCtx, c * selectCellSize, r * selectCellSize, selectCellSize, item.color, 1, 1);
                        });
                    });
                    
                    itemCard.onclick = function() { GameApp.Core.selectThisCustomShape(item, this); };
                    wrapper.appendChild(itemCard);
                    
                    let nameTag = document.createElement('span');
                    nameTag.className = 'select-item-name';
                    nameTag.innerText = item.name;
                    wrapper.appendChild(nameTag);
                    
                    this.elements.customSelectPanel.appendChild(wrapper);
                });
            },

            updateScoreDisplay: function() {
                const t = GameApp.I18N;
                const s = GameApp.State;
                
                this.elements.topScoreText.innerText = `${t.getText('score')}: ${s.bScore}`;
                if (s.currentMode === 'level') { 
                    this.elements.topScoreText.innerText = `${t.getText('stage')} ${s.currentLevel}: ${s.bScore} / ${s.targetScore}`; 
                }
                if (s.currentMode === 'lucky') { 
                    this.elements.luckyProgressBar.innerText = `${t.getText('luckyProgress')}: ${s.luckyLinesNeeded} ${t.getText('rows')}`; 
                }
                
                this.elements.clearMultiplierTag.innerText = `${t.getText('multiplier')}: ${s.currentMultiplier.toFixed(1)}x`;
                this.elements.topBestText.innerText = `${t.getText('best')}: ${s.bBestScore}`;
            },

            openSettingsModal: function() { this.elements.settingsOverlay.style.display = 'flex'; },
            closeSettingsModal: function() { this.elements.settingsOverlay.style.display = 'none'; },
            
            triggerReplayFromSettings: function() {
                this.closeSettingsModal();
                GameApp.AdsManager.showInterstitial(() => {
                    GameApp.Core.clearSavedGame();
                    GameApp.Core.resetGame();
                });
            },
            
            triggerMenuFromSettings: function() {
                this.closeSettingsModal();
                GameApp.Core.saveCurrentGame();
                GameApp.Core.exitToMenu();
            },
            
            toggleLevelSelect: function(e) {
                e.stopPropagation();
                const panel = this.elements.levelPanel;
                panel.style.display = panel.style.display === 'grid' ? 'none' : 'grid';
            },

            showGameOverModal: function(isWin) {
                GameApp.State.isGameOver = true;
                this.elements.gameoverOverlay.style.display = 'flex';
                const t = GameApp.I18N;
                
                if (GameApp.State.currentMode === 'level') {
                    this.elements.modalTitle.innerText = isWin ? t.getText('goWin') : t.getText('goLose');
                    this.elements.modalScoreText.innerText = isWin ? `${t.getText('goWinDesc')} ${GameApp.State.targetScore}` : t.getText('goLoseDesc');
                } else {
                    this.elements.modalTitle.innerText = t.getText('goOver');
                    this.elements.modalScoreText.innerText = `${t.getText('goScore')}: ${GameApp.State.bScore}`;
                    GameApp.Core.clearSavedGame();
                }
                GameApp.AdsManager.showInterstitial(null);
            }
        };

        // ----------------------------------------------------------------------
        // MODULE: CORE ENGINE LOGIC
        // ----------------------------------------------------------------------
        GameApp.Core = {
            init: function() {
                this.loadBestScore();
                GameApp.AdsManager.init();
                this.bindEvents();
            },

            loadBestScore: function() {
                GameApp.State.bBestScore = localStorage.getItem('all_you_can_put_best_v5') ? parseInt(localStorage.getItem('all_you_can_put_best_v5')) : 0;
            },

            saveBestScore: function() {
                localStorage.setItem('all_you_can_put_best_v5', GameApp.State.bBestScore);
            },

            saveCurrentGame: function() {
                const s = GameApp.State;
                if (s.isGameOver || s.currentMode === 'level') return;
                const stateObj = {
                    bGrid: s.bGrid, bScore: s.bScore, hand: s.hand,
                    currentMode: s.currentMode, luckyLinesNeeded: s.luckyLinesNeeded,
                    allClearCount: s.allClearCount, currentMultiplier: s.currentMultiplier
                };
                localStorage.setItem('all_you_can_put_save_v5', JSON.stringify(stateObj));
            },

            checkSavedGameExists: function() {
                const saved = localStorage.getItem('all_you_can_put_save_v5');
                document.getElementById('lobby-continue-btn').style.display = saved ? 'inline-block' : 'none';
            },

            loadSavedGame: function() {
                const saved = localStorage.getItem('all_you_can_put_save_v5');
                if (!saved) return;
                const stateObj = JSON.parse(saved);
                const s = GameApp.State;
                
                document.getElementById('menu-screen').style.display = 'none';
                document.getElementById('game-screen').style.display = 'flex';
                
                s.bGrid = stateObj.bGrid; s.bScore = stateObj.bScore; s.hand = stateObj.hand;
                s.currentMode = stateObj.currentMode; s.luckyLinesNeeded = stateObj.luckyLinesNeeded;
                s.allClearCount = stateObj.allClearCount; s.currentMultiplier = stateObj.currentMultiplier;
                
                s.isGameOver = false; s.isCustomSelecting = false; s.selectedPiece = null;
                GameApp.UI.elements.luckyProgressBar.style.display = s.currentMode === 'lucky' ? 'block' : 'none';
                
                GameApp.I18N.applyLanguage();
                this.checkAndApplyDynamicTheme();
                if (!s.loopActive) { s.loopActive = true; GameApp.Render.gameTick(); }
            },

            clearSavedGame: function() {
                localStorage.removeItem('all_you_can_put_save_v5');
                this.checkSavedGameExists();
            },

            exitToMenu: function() {
                this.saveCurrentGame();
                GameApp.UI.elements.gameoverOverlay.style.display = 'none';
                GameApp.UI.elements.settingsOverlay.style.display = 'none';
                document.getElementById('menu-screen').style.display = 'block';
                document.getElementById('game-screen').style.display = 'none';
                
                // 🌟 返回主頁時還原粉藍漸變主題背景
                document.body.style.background = 'var(--bg-gradient)'; 
                
                this.checkSavedGameExists();
            },

            startLuckyMode: function() {
                this.clearSavedGame(); GameApp.State.currentMode = 'lucky';
                GameApp.UI.elements.topBestText.style.display = 'block';
                GameApp.UI.elements.luckyProgressBar.style.display = 'block';
                GameApp.UI.elements.customSelectPanel.style.display = 'none';
                this.enterArena();
            },

            startEndlessMode: function() {
                this.clearSavedGame(); GameApp.State.currentMode = 'endless';
                GameApp.UI.elements.topBestText.style.display = 'block';
                GameApp.UI.elements.luckyProgressBar.style.display = 'none';
                GameApp.UI.elements.customSelectPanel.style.display = 'none';
                this.enterArena();
            },

            startLevelMode: function(lvlNum) {
                GameApp.State.currentMode = 'level'; GameApp.State.currentLevel = lvlNum;
                GameApp.State.targetScore = this.generateLevelConfig(lvlNum).target;
                GameApp.UI.elements.topBestText.style.display = 'none';
                GameApp.UI.elements.luckyProgressBar.style.display = 'none';
                GameApp.UI.elements.customSelectPanel.style.display = 'none';
                this.enterArena();
            },

            enterArena: function() {
                document.getElementById('menu-screen').style.display = 'none';
                document.getElementById('game-screen').style.display = 'flex';
                this.resetGame(); GameApp.I18N.applyLanguage();
                if (!GameApp.State.loopActive) { GameApp.State.loopActive = true; GameApp.Render.gameTick(); }
            },

            generateLevelConfig: function(lvl) {
                let target = 150 + (lvl * 15); let obstacles = [];
                if (lvl > 55) obstacles = [{r:2, c:2}, {r:2, c:5}, {r:5, c:2}, {r:5, c:5}, {r:3, c:3}];
                else if (lvl > 35) obstacles = [{r:1, c:1}, {r:1, c:6}, {r:6, c:1}, {r:6, c:6}];
                else if (lvl > 15) obstacles = [{r:3, c:2}, {r:3, c:3}, {r:3, c:4}];
                else if (lvl > 5) obstacles = [{r:4, c:4}];
                return { target, obstacles };
            },

            resetGame: function() {
                const s = GameApp.State; const size = GameApp.Config.bGridSize;
                GameApp.UI.elements.gameoverOverlay.style.display = 'none';
                GameApp.UI.elements.luckyChestOverlay.style.display = 'none';
                GameApp.UI.elements.customSelectPanel.style.display = 'none';
                
                s.bGrid = Array(size).fill(null).map(() => Array(size).fill(0));
                s.bScore = 0; s.isGameOver = false; s.luckyLinesNeeded = 3; s.isCustomSelecting = false; s.allClearCount = 0; s.currentMultiplier = 1.0; s.allClearFlashTimer = 0; s.selectedPiece = null;
                s.particles = []; s.clearingCells = [];
                s.gridBounceX = Array(size).fill().map(() => Array(size).fill(1)); s.gridBounceY = Array(size).fill().map(() => Array(size).fill(1));
                s.gridVelocityX = Array(size).fill().map(() => Array(size).fill(0)); s.gridVelocityY = Array(size).fill().map(() => Array(size).fill(0));

                if (s.currentMode === 'level') this.generateLevelConfig(s.currentLevel).obstacles.forEach(obs => { s.bGrid[obs.r][obs.c] = '#4e566d'; });
                
                this.checkAndApplyDynamicTheme(); GameApp.UI.updateScoreDisplay(); this.generateHand();
            },

            // 🧠 核心：模擬消除測試 (用於 AI 放水)
            simulateLineClear: function(shape, targetR, targetC) {
                const s = GameApp.State;
                const size = GameApp.Config.bGridSize;
                let tempGrid = s.bGrid.map(row => [...row]);
                
                // 假裝放進去
                for(let r=0; r<shape.length; r++) {
                    for(let c=0; c<shape[r].length; c++) {
                        if(shape[r][c]) tempGrid[targetR+r][targetC+c] = 1;
                    }
                }

                // 檢查是否達成整行或整列
                for(let r=0; r<size; r++) {
                    if(tempGrid[r].every(cell => cell !== 0 && cell !== '#4e566d')) return true;
                }
                for(let c=0; c<size; c++) {
                    let m = true;
                    for(let r=0; r<size; r++) {
                        if(tempGrid[r][c] === 0 || tempGrid[r][c] === '#4e566d') m = false;
                    }
                    if(m) return true;
                }
                return false;
            },

            // 🧠 核心：AI 智能讀心放水系統 & 牌組生成
            generateHand: function() {
                const s = GameApp.State;
                s.hand = [];
                
                // --- 1. AI 智能檢測與保底 ---
                let smartPiece = null;
                // 分數越低，AI越幫你作弊；超過 1500分 AI不再干預
                let assistChance = 0;
                if (s.bScore < 600) assistChance = 1.0;      // 100% 幫忙
                else if (s.bScore < 1500) assistChance = 0.4; // 40% 幫忙
                
                if (Math.random() < assistChance && (s.currentMode === 'endless' || s.currentMode === 'lucky')) {
                    // 將容易拼接的形狀洗牌
                    let pool = [...GameApp.Config.Shapes.easy, ...GameApp.Config.Shapes.medium].sort(() => Math.random() - 0.5);
                    
                    // 掃描棋盤找出可以立刻消除的空缺
                    for(let piece of pool) {
                        let canClear = false;
                        for(let r=0; r<GameApp.Config.bGridSize; r++) {
                            for(let c=0; c<GameApp.Config.bGridSize; c++) {
                                if(this.canPlaceShape(piece.matrix, r, c)) {
                                    if (this.simulateLineClear(piece.matrix, r, c)) {
                                        smartPiece = piece;
                                        canClear = true;
                                        break;
                                    }
                                }
                            }
                            if(canClear) break;
                        }
                        if(smartPiece) break;
                    }
                }

                // --- 2. 常規發牌 ---
                for(let i=0; i<3; i++) {
                    // 如果有智能方塊，強制塞入第一個位置
                    if (i === 0 && smartPiece) {
                        s.hand.push({ shape: smartPiece.matrix, color: smartPiece.color, x: 35, y: 520, origX: 35, origY: 520, isUsed: false });
                        continue;
                    }
                    
                    let pool = GameApp.Config.Shapes.easy;
                    let roll = Math.random();
                    
                    if (s.currentMode === 'endless' || s.currentMode === 'lucky') {
                        if (s.bScore >= 1200) pool = roll < 0.2 ? GameApp.Config.Shapes.hard : GameApp.Config.Shapes.medium;
                        else if (s.bScore >= 500) pool = roll < 0.35 ? GameApp.Config.Shapes.medium : GameApp.Config.Shapes.easy;
                    } else {
                        if (s.currentLevel > 40) pool = roll < 0.25 ? GameApp.Config.Shapes.hard : GameApp.Config.Shapes.medium;
                    }
                    
                    const target = pool[Math.floor(Math.random() * pool.length)];
                    s.hand.push({ shape: target.matrix, color: target.color, x: 35 + i * 140, y: 520, origX: 35 + i * 140, origY: 520, isUsed: false });
                }
                this.saveCurrentGame();
            },

            triggerHapticShock: function(duration) {
                if (navigator.vibrate) {
                    try { navigator.vibrate(duration); } catch(e) {}
                }
            },

            checkAndApplyDynamicTheme: function() {
                const body = document.body;
                const arenaPanel = document.getElementById('gameArenaPanel');
                const s = GameApp.State;
                const t = GameApp.Config.Themes;
                
                if (s.bScore >= 1000) s.currentTheme = t.universe;
                else if (s.bScore >= 600) s.currentTheme = t.sunset;
                else if (s.bScore >= 300) s.currentTheme = t.grass;
                else s.currentTheme = t.sea;

                body.style.background = s.currentTheme.bg;
                arenaPanel.style.background = s.currentTheme.panel;
            },

            getSnapCoordinates: function() {
                const s = GameApp.State; const cellSize = GameApp.Config.bCellSize;
                const targetX = s.mouseX - s.dragOffset.x; const targetY = s.mouseY - s.dragOffset.y - 85; 
                return { gridX: Math.round(targetX / cellSize), gridY: Math.round(targetY / cellSize) };
            },

            canPlaceShape: function(shape, targetR, targetC) {
                const s = GameApp.State; const size = GameApp.Config.bGridSize;
                for(let r=0; r<shape.length; r++) {
                    for(let c=0; c<shape[r].length; c++) {
                        if(shape[r][c]) {
                            let nr = targetR + r; let nc = targetC + c;
                            if(nr < 0 || nr >= size || nc < 0 || nc >= size || s.bGrid[nr][nc] !== 0) return false;
                        }
                    }
                }
                return true;
            },

            placeShape: function(shape, targetR, targetC, color, scoreGain) {
                const s = GameApp.State;
                for(let r=0; r<shape.length; r++) {
                    for(let c=0; c<shape[r].length; c++) {
                        if(shape[r][c]) s.bGrid[targetR+r][targetC+c] = color;
                    }
                }
                s.bScore += Math.round(scoreGain * s.currentMultiplier);
                GameApp.UI.updateScoreDisplay(); this.checkAndApplyDynamicTheme();
            },

            checkAllClearCondition: function() {
                const s = GameApp.State; const size = GameApp.Config.bGridSize;
                let isBoardEmpty = true;
                for(let r=0; r<size; r++) {
                    for(let c=0; c<size; c++) {
                        if(s.bGrid[r][c] !== 0 && s.bGrid[r][c] !== '#4e566d') { isBoardEmpty = false; break; }
                    }
                    if(!isBoardEmpty) break;
                }
                if (isBoardEmpty) {
                    s.allClearCount++;
                    if (s.allClearCount === 1) s.currentMultiplier = 1.2;
                    else if (s.allClearCount === 2) s.currentMultiplier = 1.4;
                    else if (s.allClearCount === 3) s.currentMultiplier = 1.6;
                    else s.currentMultiplier = 2.0; 
                    
                    this.triggerHapticShock(80); 
                    s.allClearFlashTimer = 1.0; 
                    GameApp.UI.updateScoreDisplay();
                }
            },

            checkLineClears: function() {
                const s = GameApp.State; const size = GameApp.Config.bGridSize;
                let rows = []; let cols = [];
                
                for(let r=0; r<size; r++) if(s.bGrid[r].every(cell => cell !== 0 && cell !== '#4e566d')) rows.push(r);
                for(let c=0; c<size; c++) {
                    let m = true;
                    for(let r=0; r<size; r++) if(s.bGrid[r][c] === 0 || s.bGrid[r][c] === '#4e566d') m = false;
                    if(m) cols.push(c);
                }
                
                let linesCount = rows.length + cols.length;
                
                if (s.currentMode === 'lucky' && linesCount > 0) {
                    s.luckyLinesNeeded -= linesCount;
                    if (s.luckyLinesNeeded <= 0) {
                        s.luckyLinesNeeded = GameApp.Config.luckyLineTarget;
                        setTimeout(this.triggerChestPopup.bind(this), 500); 
                    }
                }

                if (linesCount > 0) this.triggerHapticShock(35 * linesCount);

                const bCell = GameApp.Config.bCellSize;
                rows.forEach((r, rIndex) => {
                    setTimeout(() => {
                        for(let c=0; c<size; c++) {
                            s.clearingCells.push({ r: r, c: c, color: s.bGrid[r][c], scale: 1 });
                            this.generateParticles(c * bCell + bCell/2, r * bCell + bCell/2, s.bGrid[r][c]);
                        }
                    }, rIndex * 80);
                });

                cols.forEach((c, cIndex) => {
                    setTimeout(() => {
                        for(let r=0; r<size; r++) {
                            if(!s.clearingCells.some(cell => cell.r === r && cell.c === c)) {
                                s.clearingCells.push({ r: r, c: c, color: s.bGrid[r][c], scale: 1 });
                                this.generateParticles(c * bCell + bCell/2, r * bCell + bCell/2, s.bGrid[r][c]);
                            }
                        }
                    }, cIndex * 80);
                });

                rows.forEach(r => s.bGrid[r].fill(0));
                cols.forEach(c => { for(let r=0; r<size; r++) s.bGrid[r][c] = 0; });
                
                if(linesCount > 0) {
                    s.bScore += Math.round(linesCount * 120 * s.currentMultiplier);
                    GameApp.UI.updateScoreDisplay();
                }
            },

            generateParticles: function(x, y, color) {
                const s = GameApp.State;
                for(let i=0; i<20; i++) {
                    s.particles.push({ x: x, y: y, vx: (Math.random() - 0.5) * 12, vy: (Math.random() - 0.8) * 12, radius: Math.random() * 4.5 + 1.5, alpha: 1, color: color });
                }
            },

            checkGameOver: function() {
                const s = GameApp.State; const size = GameApp.Config.bGridSize;
                let remains = s.hand.filter(p => !p.isUsed);
                if(remains.length === 0) return false;
                for(let piece of remains) {
                    for(let r=0; r<size; r++) {
                        for(let c=0; c<size; c++) {
                            if(this.canPlaceShape(piece.shape, r, c)) return false; 
                        }
                    }
                }
                return true; 
            },

            getEventPos: function(e) {
                const canvas = GameApp.UI.elements.canvas;
                const rect = canvas.getBoundingClientRect();
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                return { x: clientX - rect.left, y: clientY - rect.top };
            },

            isInteractionBlocked: function() {
                const ui = GameApp.UI.elements; const s = GameApp.State;
                return (s.isGameOver || ui.settingsOverlay.style.display === 'flex' || ui.luckyChestOverlay.style.display === 'flex' || s.isCustomSelecting);
            },

            bindEvents: function() {
                const canvas = GameApp.UI.elements.canvas;
                
                canvas.addEventListener('mousedown', (e) => {
                    if (this.isInteractionBlocked()) return;
                    this.handleInputStart(this.getEventPos(e));
                });
                
                canvas.addEventListener('mousemove', (e) => {
                    if (this.isInteractionBlocked()) return;
                    this.handleInputMove(this.getEventPos(e));
                });
                
                window.addEventListener('mouseup', () => {
                    if (this.isInteractionBlocked() && !GameApp.State.selectedPiece) return;
                    this.handleInputEnd();
                });

                canvas.addEventListener('touchstart', (e) => {
                    if (this.isInteractionBlocked()) return; e.preventDefault();
                    this.handleInputStart(this.getEventPos(e));
                }, { passive: false });
                
                canvas.addEventListener('touchmove', (e) => {
                    if (this.isInteractionBlocked()) return; e.preventDefault();
                    this.handleInputMove(this.getEventPos(e));
                }, { passive: false });
                
                window.addEventListener('touchend', () => {
                    if (this.isInteractionBlocked() && !GameApp.State.selectedPiece) return;
                    this.handleInputEnd();
                });
            },

            handleInputStart: function(pos) {
                const s = GameApp.State; const bCell = GameApp.Config.bCellSize;
                s.mouseX = pos.x; s.mouseY = pos.y;
                
                s.hand.forEach(piece => {
                    if(piece.isUsed) return;
                    if(s.mouseX >= piece.x - 20 && s.mouseX <= piece.x + 120 && s.mouseY >= piece.y - 20 && s.mouseY <= piece.y + 120) {
                        s.selectedPiece = piece;
                        s.dragOffset.x = (piece.shape[0].length * bCell) / 2;
                        s.dragOffset.y = (piece.shape.length * bCell) / 2;
                    }
                });
            },

            handleInputMove: function(pos) { GameApp.State.mouseX = pos.x; GameApp.State.mouseY = pos.y; },

            handleInputEnd: function() {
                const s = GameApp.State;
                if (!s.selectedPiece) return;
                
                const { gridX, gridY } = this.getSnapCoordinates();
                
                if(this.canPlaceShape(s.selectedPiece.shape, gridY, gridX)) {
                    let baseGain = 15; let finalGain = Math.round(baseGain * s.currentMultiplier);
                    this.placeShape(s.selectedPiece.shape, gridY, gridX, s.selectedPiece.color, finalGain);
                    GameApp.Render.triggerSoftJelly(gridY, gridX, s.selectedPiece.shape);
                    s.selectedPiece.isUsed = true;
                    this.triggerHapticShock(20); 
                    
                    this.checkLineClears(); this.checkAllClearCondition();
                    if(s.hand.every(p => p.isUsed)) this.generateHand();
                    
                    if (s.currentMode === 'endless' || s.currentMode === 'lucky') {
                        if (s.bScore > s.bBestScore) { s.bBestScore = s.bScore; this.saveBestScore(); GameApp.UI.elements.topBestText.innerText = `${GameApp.I18N.getText('best')}: ${s.bBestScore}`; }
                        this.saveCurrentGame();
                    }
                    if (s.currentMode === 'level' && s.bScore >= s.targetScore) GameApp.UI.showGameOverModal(true);
                    else if(this.checkGameOver()) GameApp.UI.showGameOverModal(false);
                }
                s.selectedPiece = null; 
            },

            // ======================================================================
            // 🔮 寶箱與自選 3 連抽系統 (PICK 3 SYSTEM)
            // ======================================================================
            triggerChestPopup: function() {
                const s = GameApp.State;
                s.selectedPiece = null; 
                GameApp.UI.elements.luckyChestOverlay.style.display = 'flex';
            },

            drawLuckyChest: function() {
                GameApp.UI.elements.luckyChestOverlay.style.display = 'none';
                const s = GameApp.State; const t = GameApp.I18N;
                let rng = Math.random();
                
                if (rng < 0.05) { 
                    s.bScore = s.bScore * 2; alert(t.getText('alertX2')); 
                } else if (rng < 0.50) { 
                    alert(t.getText('alertDot')); s.hand = []; 
                    for(let i=0; i<3; i++) s.hand.push({ shape: [[1]], color: '#00ff66', x: 35 + i * 140, y: 520, origX: 35 + i * 140, origY: 520, isUsed: false });
                } else { 
                    alert(t.getText('alertSelect')); 
                    
                    // 🌟 啟動自選 3 連抽
                    s.isCustomSelecting = true; 
                    s.hand = []; // 清空手牌
                    s.customPicksLeft = 3; // 給予3次挑選機會
                    
                    // 恢復所有面板卡片為可選狀態
                    document.querySelectorAll('.select-item-card').forEach(el => {
                        el.style.opacity = '1';
                        el.style.pointerEvents = 'auto';
                        el.style.filter = 'grayscale(0%)';
                    });
                    
                    GameApp.UI.elements.customSelectPanel.style.display = 'flex'; 
                }
                
                GameApp.UI.updateScoreDisplay(); this.saveCurrentGame();
            },

            selectThisCustomShape: function(item, uiElement) {
                const s = GameApp.State;
                if (!s.isCustomSelecting) return;
                
                // 如果已經點過，不允許重複選擇
                if (uiElement.style.opacity === '0.3') return;
                
                // 把選擇的形狀加入手牌 (按照挑選順序排列 0, 1, 2)
                let slotIndex = 3 - s.customPicksLeft;
                s.hand.push({ 
                    shape: item.matrix, 
                    color: item.color, 
                    x: 35 + slotIndex * 140, 
                    y: 520, 
                    origX: 35 + slotIndex * 140, 
                    origY: 520, 
                    isUsed: false 
                });
                
                // 將該卡片變暗，標記為已使用
                uiElement.style.opacity = '0.3';
                uiElement.style.pointerEvents = 'none';
                uiElement.style.filter = 'grayscale(100%)';
                
                s.customPicksLeft--;
                
                // 如果 3 次選完了，關閉面板
                if (s.customPicksLeft <= 0) {
                    s.isCustomSelecting = false; 
                    GameApp.UI.elements.customSelectPanel.style.display = 'none'; 
                }
                
                GameApp.UI.updateScoreDisplay(); this.saveCurrentGame();
            }
        };

        // ----------------------------------------------------------------------
        // MODULE: RENDERING ENGINE (渲染引擎)
        // ----------------------------------------------------------------------
        GameApp.Render = {
            gameTick: function() {
                const s = GameApp.State; const size = GameApp.Config.bGridSize;
                
                if (document.getElementById('game-screen').style.display === 'flex') {
                    for (let i = s.particles.length - 1; i >= 0; i--) {
                        let p = s.particles[i]; p.x += p.vx; p.y += p.vy; p.vy += 0.35; p.alpha -= 0.02; p.radius *= 0.96; 
                        if (p.alpha <= 0) s.particles.splice(i, 1);
                    }
                    for (let i = s.clearingCells.length - 1; i >= 0; i--) { 
                        s.clearingCells[i].scale -= 0.08; 
                        if (s.clearingCells[i].scale <= 0) s.clearingCells.splice(i, 1); 
                    }
                    for(let r=0; r<size; r++) {
                        for(let c=0; c<size; c++) {
                            let ax = (1 - s.gridBounceX[r][c]) * 0.28; s.gridVelocityX[r][c] += ax; s.gridVelocityX[r][c] *= 0.65; s.gridBounceX[r][c] += s.gridVelocityX[r][c];
                            let ay = (1 - s.gridBounceY[r][c]) * 0.28; s.gridVelocityY[r][c] += ay; s.gridVelocityY[r][c] *= 0.65; s.gridBounceY[r][c] += s.gridVelocityY[r][c];
                        }
                    }
                    if (s.allClearFlashTimer > 0) s.allClearFlashTimer -= 0.04;
                    this.drawGame();
                }
                requestAnimationFrame(this.gameTick.bind(this));
            },

            triggerSoftJelly: function(row, col, matrix) {
                const s = GameApp.State; const size = GameApp.Config.bGridSize;
                for(let r=0; r<matrix.length; r++) {
                    for(let c=0; c<matrix[r].length; c++) {
                        if(matrix[r][c]) {
                            let tr = row + r; let tc = col + c; 
                            if(tr >= 0 && tr < size && tc >= 0 && tc < size) { s.gridBounceX[tr][tc] = 1.25; s.gridBounceY[tr][tc] = 0.75; }
                        }
                    }
                }
            },

            drawTexturedCandyCell: function(renderCtx, x, y, size, color, scaleX, scaleY) {
                renderCtx.save();
                const w = (size - 4) * scaleX; const h = (size - 4) * scaleY;
                const ox = x + 2 + (size - 4 - w)/2; const oy = y + 2 + (size - 4 - h)/2;
                
                renderCtx.fillStyle = color; renderCtx.fillRect(ox, oy, w, h);
                let grad = renderCtx.createLinearGradient(ox, oy, ox, oy + h);
                grad.addColorStop(0, "rgba(255,255,255,0.5)"); grad.addColorStop(0.3, "rgba(255,255,255,0.05)"); grad.addColorStop(1, "rgba(0,0,0,0.25)");
                renderCtx.fillStyle = grad; renderCtx.fillRect(ox, oy, w, h);
                
                renderCtx.strokeStyle = "rgba(255,255,255,0.3)"; renderCtx.lineWidth = 1.5; renderCtx.strokeRect(ox + 1, oy + 1, w - 2, h - 2);
                renderCtx.restore();
            },

            drawPiece: function(piece, startX, startY, cellSize) {
                piece.shape.forEach((row, rIdx) => {
                    row.forEach((val, cIdx) => {
                        if(val) this.drawTexturedCandyCell(GameApp.UI.elements.ctx, startX + cIdx * cellSize, startY + rIdx * cellSize, cellSize, piece.color, 1, 1);
                    });
                });
            },

            drawGame: function() {
                const s = GameApp.State; const ctx = GameApp.UI.elements.ctx; const canvas = GameApp.UI.elements.canvas;
                const bCell = GameApp.Config.bCellSize; const size = GameApp.Config.bGridSize;

                ctx.clearRect(0, 0, canvas.width, canvas.height); 
                ctx.fillStyle = s.currentTheme.canvasFill; ctx.fillRect(0, 0, canvas.width, canvas.height);
                
                for(let r=0; r<size; r++) {
                    for(let c=0; c<size; c++) {
                        if(s.clearingCells.some(cell => cell.r === r && cell.c === c)) continue;
                        let cellVal = s.bGrid[r][c];
                        if (cellVal) this.drawTexturedCandyCell(ctx, c * bCell, r * bCell, bCell, cellVal, s.gridBounceX[r][c], s.gridBounceY[r][c]);
                        else { ctx.fillStyle = s.currentTheme.emptyCell; ctx.fillRect(c * bCell + 2, r * bCell + 2, bCell - 4, bCell - 4); }
                    }
                }

                s.clearingCells.forEach(cell => {
                    ctx.save(); this.drawTexturedCandyCell(ctx, cell.c * bCell, cell.r * bCell, bCell, cell.color, cell.scale, cell.scale); ctx.restore();
                });

                if (s.selectedPiece && !s.isGameOver) {
                    const { gridX, gridY } = GameApp.Core.getSnapCoordinates();
                    if (GameApp.Core.canPlaceShape(s.selectedPiece.shape, gridY, gridX)) {
                        ctx.fillStyle = "rgba(255, 255, 255, 0.2)"; 
                        s.selectedPiece.shape.forEach((row, rIdx) => {
                            row.forEach((val, cIdx) => { if(val) ctx.fillRect((gridX+cIdx)*bCell+2, (gridY+rIdx)*bCell+2, bCell-4, bCell-4); });
                        });
                    }
                }

                s.particles.forEach(p => { ctx.save(); ctx.globalAlpha = p.alpha; ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2); ctx.fill(); ctx.restore(); });
                
                if (s.allClearFlashTimer > 0) {
                    ctx.save(); ctx.globalAlpha = s.allClearFlashTimer; ctx.fillStyle = "#ffffff"; ctx.fillRect(0, 0, canvas.width, canvas.height); ctx.restore();
                }

                ctx.fillStyle = "rgba(0,0,0,0.4)"; ctx.fillRect(0, canvas.width, canvas.width, canvas.height - canvas.width);
                s.hand.forEach(piece => { if (!piece.isUsed && piece !== s.selectedPiece) this.drawPiece(piece, piece.x, piece.y, 24); });
                
                if (s.selectedPiece && !s.isGameOver) {
                    this.drawPiece(s.selectedPiece, s.mouseX - s.dragOffset.x, s.mouseY - s.dragOffset.y - 85, bCell);
                }
            }
        };

        // ==========================================================================
        // 9. BOOTSTRAP INITIALIZATION
        // ==========================================================================
        window.onload = function() {
            GameApp.UI.init();
            GameApp.I18N.init();
            GameApp.Core.init();
            console.log("All You Can Put! Grand Master Edition Initialized.");
        };

    </script>
</body>
</html>