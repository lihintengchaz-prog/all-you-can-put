            bGrid: [],
            bScore: 0,
            bBestScore: 0,
            hand: [],
            selectedPiece: null,
            
            currentMode: 'endless', 
            currentLevel: 1,
            targetScore: 0,
            isGameOver: false,
            
            luckyLinesNeeded: 3,
            isCustomSelecting: false,
            customPicksLeft: 0, // 新增：記錄自選剩餘次數
            allClearCount: 0,
            currentMultiplier: 1.0,
            
            particles: [],
            clearingCells: [],
            allClearFlashTimer: 0,
            currentTheme: GameApp.Config.Themes.sea,
            
            mouseX: 0, mouseY: 0,
            dragOffset: { x: 0, y: 0 },
            
            gridBounceX: [], gridBounceY: [],
            gridVelocityX: [], gridVelocityY: [],
            loopActive: false
        };

